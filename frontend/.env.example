# Put these values in your terminal environment or in a local .env file.
# Do not commit .env, access tokens, refresh tokens, or Cloudflare cookies.
PW_ORGANIZATION_ID=5eb393ee95fab7468a79d189
PW_CLIENT_ID=system-admin
PW_CLIENT_SECRET=replace_with_your_official_client_secret
# Used only by the local Node server for the BatchInfo subject route.
# Never put this value in app.js or commit it.
PWTHOR_BEARER_TOKEN=replace_with_your_current_access_token
# This token is used by the local Node server to call PWThor's BatchInfo endpoints
PORT=3000
